# ============================================================
# BEP Comms — Environment Variables
# Add these as GitHub Secrets + Cloudflare Worker env vars
# Never commit this file
# ============================================================

# Supabase (same project as dashboard)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Cliniko
CLINIKO_API_KEY=your_cliniko_api_key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+61xxxxxxxxx

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=hello@beachsideep.com.au
SENDGRID_FROM_NAME=Beachside Exercise Physiology

# Dashboard auth (same as main dashboard)
DASHBOARD_EMAIL=admin@beachsideep.com.au
DASHBOARD_PASSWORD=your_password
